---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Nebula Defender">
    <section class="py-6 space-y-5">
        <h1>🚀 Nebula Defender</h1>
        <p class="max-w-3xl text-lg text-white/85">
            Real game, real code: move with <strong>WASD</strong> or <strong>arrow keys</strong>, aim with your
            mouse, and hold <strong>left click</strong> (or press <strong>Space</strong>) to fire. Survive waves,
            defeat enemies, and beat your high score.
        </p>

        <div class="grid gap-6 lg:grid-cols-[1fr_18rem]">
            <div class="relative overflow-hidden border rounded-xl border-white/20 bg-black/40">
                <canvas id="game" width="960" height="540" class="block w-full h-auto"></canvas>
                <div id="overlay" class="absolute inset-0 flex items-center justify-center p-6 text-center bg-black/45">
                    <div class="space-y-4">
                        <h2 id="overlay-title">Nebula Defender</h2>
                        <p id="overlay-text" class="text-white/85">Fight off incoming drones and asteroids.</p>
                        <button id="start-btn" class="btn btn-lg">Start Mission</button>
                    </div>
                </div>
            </div>

            <aside class="p-5 space-y-4 border rounded-xl border-white/20 bg-black/25">
                <h2 class="text-xl">HUD</h2>
                <dl class="space-y-2">
                    <div class="flex justify-between"><dt>Score</dt><dd id="score" class="font-bold">0</dd></div>
                    <div class="flex justify-between"><dt>High Score</dt><dd id="best" class="font-bold">0</dd></div>
                    <div class="flex justify-between"><dt>Wave</dt><dd id="wave" class="font-bold">1</dd></div>
                    <div class="flex justify-between"><dt>Health</dt><dd id="health" class="font-bold">100</dd></div>
                    <div class="flex justify-between"><dt>Reload</dt><dd id="reload" class="font-bold">Ready</dd></div>
                </dl>
                <p class="text-sm text-white/70">Shoot red drones and dodge gray asteroids. Every 20 kills starts a harder wave.</p>
            </aside>
        </div>
    </section>
</Layout>

<script>
    const canvas = document.getElementById('game');
    const ctx = canvas.getContext('2d');

    const ui = {
        score: document.getElementById('score'),
        best: document.getElementById('best'),
        wave: document.getElementById('wave'),
        health: document.getElementById('health'),
        reload: document.getElementById('reload'),
        overlay: document.getElementById('overlay'),
        overlayTitle: document.getElementById('overlay-title'),
        overlayText: document.getElementById('overlay-text'),
        startBtn: document.getElementById('start-btn'),
    };

    const keys = new Set();
    const pointer = { x: canvas.width / 2, y: canvas.height / 2, down: false };
    const stars = Array.from({ length: 130 }, () => ({
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        speed: Math.random() * 0.8 + 0.3,
        size: Math.random() * 2 + 0.6,
    }));

    const state = {
        running: false,
        score: 0,
        kills: 0,
        wave: 1,
        health: 100,
        enemies: [],
        asteroids: [],
        bullets: [],
        particles: [],
        enemyTimer: 0,
        asteroidTimer: 0,
        player: {
            x: canvas.width / 2,
            y: canvas.height / 2,
            radius: 16,
            speed: 320,
            fireAt: -Infinity,
            fireCooldown: 0.12,
            facing: 0,
        },
    };

    let bestScore = Number(localStorage.getItem('nebula-best') || 0);
    ui.best.textContent = String(bestScore);

    const clamp = (n, min, max) => Math.max(min, Math.min(max, n));
    const rand = (min, max) => min + Math.random() * (max - min);

    function resetGame() {
        state.running = true;
        state.score = 0;
        state.kills = 0;
        state.wave = 1;
        state.health = 100;
        state.enemies = [];
        state.asteroids = [];
        state.bullets = [];
        state.particles = [];
        state.enemyTimer = 0;
        state.asteroidTimer = 1;
        state.player.x = canvas.width / 2;
        state.player.y = canvas.height / 2;
        state.player.fireAt = -Infinity;
        ui.overlay.classList.add('hidden');
    }

    function spawnEnemy() {
        const edge = Math.floor(rand(0, 4));
        const pad = 30;
        let x = 0;
        let y = 0;
        if (edge === 0) {
            x = rand(0, canvas.width);
            y = -pad;
        } else if (edge === 1) {
            x = canvas.width + pad;
            y = rand(0, canvas.height);
        } else if (edge === 2) {
            x = rand(0, canvas.width);
            y = canvas.height + pad;
        } else {
            x = -pad;
            y = rand(0, canvas.height);
        }
        state.enemies.push({ x, y, radius: rand(12, 19), speed: rand(70, 120) + state.wave * 12, hp: 2 + Math.floor(state.wave / 2) });
    }

    function spawnAsteroid() {
        const y = rand(20, canvas.height - 20);
        const radius = rand(15, 32);
        const fromLeft = Math.random() > 0.5;
        state.asteroids.push({ x: fromLeft ? -radius : canvas.width + radius, y, radius, vx: fromLeft ? rand(80, 170) : -rand(80, 170), spin: rand(0, Math.PI * 2) });
    }

    function shoot(now) {
        if (now - state.player.fireAt < state.player.fireCooldown) return;
        state.player.fireAt = now;
        const angle = Math.atan2(pointer.y - state.player.y, pointer.x - state.player.x);
        const speed = 560;
        state.bullets.push({
            x: state.player.x + Math.cos(angle) * 20,
            y: state.player.y + Math.sin(angle) * 20,
            vx: Math.cos(angle) * speed,
            vy: Math.sin(angle) * speed,
            life: 1.2,
            radius: 4,
        });
    }

    function addExplosion(x, y, color, amount = 10) {
        for (let i = 0; i < amount; i += 1) {
            const ang = rand(0, Math.PI * 2);
            const force = rand(40, 180);
            state.particles.push({
                x,
                y,
                vx: Math.cos(ang) * force,
                vy: Math.sin(ang) * force,
                life: rand(0.2, 0.8),
                color,
            });
        }
    }

    function update(dt, now) {
        if (!state.running) return;

        const p = state.player;
        const ax = (keys.has('arrowright') || keys.has('d') ? 1 : 0) - (keys.has('arrowleft') || keys.has('a') ? 1 : 0);
        const ay = (keys.has('arrowdown') || keys.has('s') ? 1 : 0) - (keys.has('arrowup') || keys.has('w') ? 1 : 0);
        const mag = Math.hypot(ax, ay) || 1;
        p.x += (ax / mag) * p.speed * dt;
        p.y += (ay / mag) * p.speed * dt;
        p.x = clamp(p.x, p.radius, canvas.width - p.radius);
        p.y = clamp(p.y, p.radius, canvas.height - p.radius);
        p.facing = Math.atan2(pointer.y - p.y, pointer.x - p.x);

        if (pointer.down || keys.has(' ')) shoot(now);

        state.enemyTimer -= dt;
        const enemyDelay = clamp(1.1 - state.wave * 0.08, 0.22, 1.1);
        if (state.enemyTimer <= 0) {
            spawnEnemy();
            state.enemyTimer = enemyDelay;
        }

        state.asteroidTimer -= dt;
        if (state.asteroidTimer <= 0) {
            spawnAsteroid();
            state.asteroidTimer = clamp(3.2 - state.wave * 0.15, 1.4, 3.2);
        }

        for (const b of state.bullets) {
            b.x += b.vx * dt;
            b.y += b.vy * dt;
            b.life -= dt;
        }
        state.bullets = state.bullets.filter((b) => b.life > 0 && b.x > -20 && b.x < canvas.width + 20 && b.y > -20 && b.y < canvas.height + 20);

        for (const e of state.enemies) {
            const dx = p.x - e.x;
            const dy = p.y - e.y;
            const dist = Math.hypot(dx, dy) || 1;
            e.x += (dx / dist) * e.speed * dt;
            e.y += (dy / dist) * e.speed * dt;
            if (dist < e.radius + p.radius) {
                state.health -= 18;
                e.hp = 0;
                addExplosion(e.x, e.y, '#fb7185', 14);
            }
        }

        for (const a of state.asteroids) {
            a.x += a.vx * dt;
            a.spin += dt;
            const hitPlayer = Math.hypot(a.x - p.x, a.y - p.y) < a.radius + p.radius;
            if (hitPlayer) {
                state.health -= 24;
                a.radius = 0;
                addExplosion(a.x, a.y, '#cbd5e1', 16);
            }
        }

        for (const b of state.bullets) {
            for (const e of state.enemies) {
                if (e.hp <= 0) continue;
                const hit = Math.hypot(b.x - e.x, b.y - e.y) < b.radius + e.radius;
                if (hit) {
                    b.life = 0;
                    e.hp -= 1;
                    addExplosion(b.x, b.y, '#fef08a', 6);
                    if (e.hp <= 0) {
                        state.score += 20;
                        state.kills += 1;
                        addExplosion(e.x, e.y, '#fb7185', 14);
                    }
                    break;
                }
            }
            for (const a of state.asteroids) {
                if (a.radius <= 0 || b.life <= 0) continue;
                const hit = Math.hypot(b.x - a.x, b.y - a.y) < b.radius + a.radius;
                if (hit) {
                    b.life = 0;
                    a.radius -= 7;
                    state.score += 4;
                    addExplosion(b.x, b.y, '#e2e8f0', 4);
                }
            }
        }

        state.enemies = state.enemies.filter((e) => e.hp > 0);
        state.asteroids = state.asteroids.filter((a) => a.radius > 8 && a.x > -80 && a.x < canvas.width + 80);

        for (const particle of state.particles) {
            particle.x += particle.vx * dt;
            particle.y += particle.vy * dt;
            particle.life -= dt;
            particle.vx *= 0.97;
            particle.vy *= 0.97;
        }
        state.particles = state.particles.filter((p2) => p2.life > 0);

        state.score += dt * 2 * state.wave;
        state.wave = 1 + Math.floor(state.kills / 20);

        if (state.health <= 0) {
            state.running = false;
            const finalScore = Math.floor(state.score);
            if (finalScore > bestScore) {
                bestScore = finalScore;
                localStorage.setItem('nebula-best', String(bestScore));
            }
            ui.overlayTitle.textContent = 'Mission Failed';
            ui.overlayText.textContent = `Score: ${finalScore}. High score: ${bestScore}.`; 
            ui.startBtn.textContent = 'Retry';
            ui.overlay.classList.remove('hidden');
        }
    }

    function drawShip() {
        const p = state.player;
        ctx.save();
        ctx.translate(p.x, p.y);
        ctx.rotate(p.facing + Math.PI / 2);

        ctx.beginPath();
        ctx.moveTo(0, -18);
        ctx.lineTo(11, 14);
        ctx.lineTo(0, 8);
        ctx.lineTo(-11, 14);
        ctx.closePath();
        ctx.fillStyle = '#22d3ee';
        ctx.fill();
        ctx.strokeStyle = '#cffafe';
        ctx.lineWidth = 2;
        ctx.stroke();

        ctx.beginPath();
        ctx.moveTo(-5, 12);
        ctx.lineTo(0, 22 + Math.random() * 5);
        ctx.lineTo(5, 12);
        ctx.fillStyle = '#f97316';
        ctx.fill();

        ctx.restore();
    }

    function render(now) {
        ctx.fillStyle = '#030712';
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        for (const s of stars) {
            s.y += s.speed;
            if (s.y > canvas.height + 5) {
                s.y = -5;
                s.x = rand(0, canvas.width);
            }
            ctx.fillStyle = '#cbd5e1';
            ctx.globalAlpha = 0.35 + s.size * 0.18;
            ctx.fillRect(s.x, s.y, s.size, s.size);
        }
        ctx.globalAlpha = 1;

        for (const b of state.bullets) {
            ctx.beginPath();
            ctx.arc(b.x, b.y, b.radius, 0, Math.PI * 2);
            ctx.fillStyle = '#fef08a';
            ctx.fill();
        }

        for (const e of state.enemies) {
            ctx.beginPath();
            ctx.arc(e.x, e.y, e.radius, 0, Math.PI * 2);
            ctx.fillStyle = '#fb7185';
            ctx.fill();
            ctx.strokeStyle = '#be123c';
            ctx.stroke();
        }

        for (const a of state.asteroids) {
            ctx.save();
            ctx.translate(a.x, a.y);
            ctx.rotate(a.spin);
            ctx.beginPath();
            for (let i = 0; i < 9; i += 1) {
                const ang = (i / 9) * Math.PI * 2;
                const jag = a.radius * (0.75 + (i % 2) * 0.25);
                const x = Math.cos(ang) * jag;
                const y = Math.sin(ang) * jag;
                i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
            }
            ctx.closePath();
            ctx.fillStyle = '#94a3b8';
            ctx.fill();
            ctx.strokeStyle = '#475569';
            ctx.stroke();
            ctx.restore();
        }

        for (const p2 of state.particles) {
            ctx.globalAlpha = clamp(p2.life * 1.8, 0, 1);
            ctx.fillStyle = p2.color;
            ctx.fillRect(p2.x, p2.y, 3, 3);
        }
        ctx.globalAlpha = 1;

        drawShip(now);
    }

    function renderHud(now) {
        ui.score.textContent = String(Math.floor(state.score));
        ui.best.textContent = String(bestScore);
        ui.wave.textContent = String(state.wave);
        ui.health.textContent = String(Math.max(0, Math.ceil(state.health)));
        const t = state.player.fireCooldown - (now - state.player.fireAt);
        ui.reload.textContent = t <= 0 ? 'Ready' : `${t.toFixed(2)}s`;
    }

    let last = performance.now() / 1000;
    function frame() {
        const now = performance.now() / 1000;
        const dt = Math.min(0.04, now - last);
        last = now;
        update(dt, now);
        render(now);
        renderHud(now);
        requestAnimationFrame(frame);
    }

    window.addEventListener('keydown', (e) => {
        keys.add(e.key.toLowerCase());
        if (e.key === ' ') e.preventDefault();
    });
    window.addEventListener('keyup', (e) => keys.delete(e.key.toLowerCase()));

    canvas.addEventListener('mousemove', (e) => {
        const rect = canvas.getBoundingClientRect();
        pointer.x = ((e.clientX - rect.left) / rect.width) * canvas.width;
        pointer.y = ((e.clientY - rect.top) / rect.height) * canvas.height;
    });
    canvas.addEventListener('mousedown', () => {
        pointer.down = true;
    });
    window.addEventListener('mouseup', () => {
        pointer.down = false;
    });

    ui.startBtn.addEventListener('click', () => {
        ui.startBtn.textContent = 'Restart';
        resetGame();
    });

    render(0);
    renderHud(0);
    requestAnimationFrame(frame);
</script>
